# Required: Your OpenAI API key for LLM narration and vision
OPENAI_API_KEY=sk-your-key-here

# Optional: Quality preset (draft, standard, pro). Default: draft
# SLIDESHERLOCK_PRESET=draft

# Optional: Enable vision pipeline (requires OpenAI API key)
# VISION_PROVIDER=openai

# Optional: Enable macOS system TTS (local dev only, not in Docker)
# USE_SYSTEM_TTS=true
